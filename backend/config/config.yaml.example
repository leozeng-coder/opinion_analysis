server:
  port: "8080"
  mode: "debug"   # debug | release

database:
  dsn: "root:YOUR_DB_PASSWORD@tcp(127.0.0.1:3306)/opinion_analysis?charset=utf8mb4&parseTime=True&loc=Local"
  maxOpenConn: 100
  maxIdleConn: 10

redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0

jwt:
  secret: "change-me-in-production"
  expireHour: 24

log:
  level: "info"
  filename: "logs/app.log"

# 前端「立即爬取」由后端在本机拉起 MindSpider/run_once.py；Docker 纯后端镜像无 Python 时请改为 enabled: false
crawler:
  enabled: true
  root: "../crawler"
  python: ""   # empty = auto-detect crawler/.venv/Scripts/python.exe

# AI 自动打标后台任务：周期性地为新文章生成 1~4 个标签
tagger:
  enabled: true
  deepseekApiKey: ""  # 留空则读 DEEPSEEK_API_KEY 环境变量；或在此填入你的 DeepSeek API Key
  deepseekBaseUrl: "https://api.deepseek.com"
  model: "deepseek-chat"
  intervalSeconds: 120              # 轮询间隔（秒）
  batchSize: 20                     # 单次 LLM 请求条数
  maxPerTick: 200                   # 单次轮询最多处理多少条，避免长时占用
