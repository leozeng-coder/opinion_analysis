server:
  port: "8080"
  mode: "debug"   # debug | release

database:
  dsn: "root:YOUR_DB_PASSWORD@tcp(127.0.0.1:3306)/opinion_analysis?charset=utf8mb4&parseTime=True&loc=Local"
  maxOpenConn: 100
  maxIdleConn: 10

redis:
  addr: "127.0.0.1:6379"
  password: ""
  db: 0

jwt:
  secret: "change-me-in-production"
  expireHour: 24

log:
  level: "info"
  filename: "logs/app.log"

# 前端「立即爬取」由后端在本机拉起 crawler/run_once.py；Docker 纯后端镜像无 Python 时请改为 enabled: false
crawler:
  enabled: true
  root: "../crawler"
  python: ""   # empty = auto-detect crawler/.venv/Scripts/python.exe

# 注意：大模型（AI 自动打标 / 情感分析）相关配置通过管理后台维护。
# 路径：管理后台 → 系统状态 → 大模型配置。
# 配置持久化在数据库 system_settings 表；如需紧急覆盖 API Key，
# 可设置环境变量 DEEPSEEK_API_KEY（仅对 Go 后端 tagger 服务有效）。

rag:
  # 智能助手 RAG（Milvus Lite + 增量向量同步）
  enabled: false
  embedding_service_url: "http://127.0.0.1:5055"
  # managed: true 时 Go 可拉起/重启本机 RAG；生产 Docker 请 false 并单独部署 RAG
  managed: false
  auto_start: true
  root: "../rag"
  python: ""
  server_script: "server.py"